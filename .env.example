# 可选：SQLite 数据库路径（默认 mappings.db）
# DB_PATH=mappings.db
# 日志级别：debug | info | warn | error
# LOG_LEVEL=info
# 可选：启用日志文件输出（同时写入 stdout 和文件）
# LOG_TO_FILE=true
# 可选：日志文件目录（默认 ./logs）
# LOG_DIR=./logs
# 可选：单个日志文件最大大小（MB，默认 10）
# LOG_MAX_SIZE_MB=10
# 可选：保留的轮转日志文件数量（默认 3）
# LOG_MAX_FILES=3
