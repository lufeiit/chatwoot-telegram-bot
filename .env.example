PORT=3000
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_ID=your_telegram_user_id
# 可选：Forum 群组 ID（启用话题隔离功能）
# TELEGRAM_FORUM_CHAT_ID=your_forum_group_id
CHATWOOT_ACCESS_TOKEN=your_chatwoot_access_token
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_ACCOUNT_ID=1
# 可选：Webhook 签名验证密钥（在 Chatwoot Webhook 设置中配置）
# CHATWOOT_WEBHOOK_SECRET=your_webhook_secret
# 可选：每行一组回复；同组关键词用 | 分隔，\n 表示换行；按书写顺序命中第一组
